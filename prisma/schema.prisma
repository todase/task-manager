generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  tasks     Task[]
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate    DateTime?
  recurrence String?
  order      Int       @default(0)
  userId     String
  user      User      @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  subtasks  Subtask[]
  createdAt DateTime  @default(now())
}


model Subtask {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Project {
  id        String   @id @default(cuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tasks     Task[]
  createdAt DateTime @default(now())
}

